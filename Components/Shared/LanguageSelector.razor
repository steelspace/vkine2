@using System
@using System.Globalization
@using System.Linq
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Options

<button type="button" class="lang-toggle" @onclick="Cycle"
        aria-label="@Localizer["LanguageSelectAria"]"
        title="@Localizer["LanguageSelectAria"]">
    <span class="lang-code">@CurrentCode</span>
</button>

@code {
    [Inject]
    private IOptions<RequestLocalizationOptions> LocalizationOptions { get; set; } = default!;

    [Inject]
    private IStringLocalizer<LanguageSelector> Localizer { get; set; } = default!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    private IReadOnlyList<CultureInfo> SupportedCultures { get; set; } = Array.Empty<CultureInfo>();

    private string CurrentCulture => CultureInfo.CurrentUICulture.Name;

    private string CurrentCode => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToUpperInvariant();

    protected override void OnInitialized()
    {
        var options = LocalizationOptions.Value;
        var cultures = options?.SupportedUICultures?.Count > 0
            ? options.SupportedUICultures
            : options?.SupportedCultures;

        SupportedCultures = cultures is not null && cultures.Count > 0
            ? cultures.ToArray()
            : new[] { CultureInfo.CurrentUICulture };
    }

    private async Task Cycle()
    {
        var current = SupportedCultures
            .FirstOrDefault(c => string.Equals(c.Name, CurrentCulture, StringComparison.OrdinalIgnoreCase));
        var idx = current is not null ? SupportedCultures.ToList().IndexOf(current) : 0;
        var next = SupportedCultures[(idx + 1) % SupportedCultures.Count];
        await JSRuntime.InvokeVoidAsync("vkineLocale.setCultureAndReload", next.Name);
    }
}
