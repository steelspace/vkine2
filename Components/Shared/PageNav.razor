<nav class="page-nav" aria-label="@Localizer["NavAria"]">
    <a class="page-nav-item @(IsMovies ? "active" : "")"
       href="/movies"
       aria-current="@(IsMovies ? "page" : null)">
        <svg class="page-nav-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="2" ry="2"/>
            <line x1="7" y1="2" x2="7" y2="22"/>
            <line x1="17" y1="2" x2="17" y2="22"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <line x1="2" y1="7" x2="7" y2="7"/>
            <line x1="2" y1="17" x2="7" y2="17"/>
            <line x1="17" y1="17" x2="22" y2="17"/>
            <line x1="17" y1="7" x2="22" y2="7"/>
        </svg>
        <span class="page-nav-label">@Localizer["Movies"]</span>
    </a>
    <a class="page-nav-item @(IsPremieres ? "active" : "")"
       href="/premieres"
       aria-current="@(IsPremieres ? "page" : null)">
        <svg class="page-nav-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <span class="page-nav-label">@Localizer["Premieres"]</span>
    </a>
</nav>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IStringLocalizer<PageNav> Localizer { get; set; } = default!;

    private bool IsMovies
    {
        get { var p = new Uri(Nav.Uri).AbsolutePath; return p is "/" or "/movies"; }
    }

    private bool IsPremieres => new Uri(Nav.Uri).AbsolutePath == "/premieres";
}
